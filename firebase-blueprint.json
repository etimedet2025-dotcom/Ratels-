{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Unique auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "receptionist"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "role"]
    },
    "Report": {
      "title": "Incident Report",
      "description": "A civic report filed by a user.",
      "type": "object",
      "properties": {
        "reportId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "investigating", "verified", "closed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "location": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "attachments": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "status", "priority", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Authenticated user profiles."
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Civic reports and complaints."
    }
  }
}
